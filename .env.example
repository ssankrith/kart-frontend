# Base URL of kart-backend (no trailing slash). Used by POST /api/order proxy (server-only).
API_BASE_URL=https://kart-backend-18if.onrender.com

# Same value the backend expects on POST /order (header api_key). Server-only — never NEXT_PUBLIC_*.
API_KEY=your-api-key

# Public base URL for browser catalog fetches (GET /product). Must match API_BASE_URL; backend needs CORS_ORIGINS.
NEXT_PUBLIC_API_BASE_URL=https://kart-backend-18if.onrender.com

# Optional: if set, GET /api/cron/keep-alive requires Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
